# {{ ansible_managed }}
# SSH config — generated by the ssh role. Do not edit manually.

{% for entry in ssh_hosts %}
Host {{ entry.host }}
    HostName {{ entry.hostname }}
    User {{ entry.user }}
    IdentityFile {{ ansible_user_dir }}/.ssh/id_ed25519_{{ entry.identity_key }}
    IdentitiesOnly yes

{% endfor %}
Host *
    AddKeysToAgent yes
    HashKnownHosts yes
    IdentityFile {{ ansible_user_dir }}/.ssh/id_ed25519_macbook
