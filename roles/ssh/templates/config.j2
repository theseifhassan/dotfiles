# {{ ansible_managed }}
# SSH config — generated by the ssh role. Do not edit manually.

{% for entry in ssh_hosts %}
Host {{ entry.host }}
    HostName {{ entry.hostname }}
    User {{ entry.user }}
    IdentityFile {{ ansible_facts['user_dir'] }}/.ssh/id_ed25519_{{ entry.identity_key }}
    IdentitiesOnly yes

{% endfor %}
# No default IdentityFile: inter-machine SSH is authenticated by Tailscale
# SSH (tailnet identity), not key files.
Host *
    AddKeysToAgent yes
    UseKeychain yes
    HashKnownHosts yes
