# {{ ansible_managed }}
# mise configuration — global defaults, rendered per profile (no secrets).
#
# secrets.env is rendered from the vault by the mise role (mode 0600, never
# committed) with this machine's profile secrets.

[env]
GRAPHITE_PROFILE = "{{ profile }}"
# Where agent workflows (SAW) create git worktrees. Zed's per-repo default
# ("../worktrees" relative to the repo) resolves to the same root for repos
# living in ~/Desktop, so both tools share one worktree tree.
SAW_WORKTREE_ROOT = "{% raw %}{{env.HOME}}{% endraw %}/Desktop/worktrees"
_.file = "~/.config/mise/secrets.env"

# Global tools. The Node-based language servers + formatters here are consumed
# by Neovim (the `neovim` role enables them via the native vim.lsp API and
# conform.nvim). They live in the global mise config — rather than being
# installed imperatively — so the declaration is version-controlled and `mise
# install` realizes them without rewriting this file. `node` provides the
# runtime for mise's npm backend.
[tools]
node = "lts"
pnpm = "latest"
bun = "latest"
