# {{ ansible_managed }}
# Work identity — generated by the git role.

[user]
    name = {{ git_identity.work.name }}
    email = {{ git_identity.work.email }}
{%- if git_identity.work.signing_key is defined and git_identity.work.signing_key %}
    signingKey = {{ git_identity.work.signing_key }}
{#- Signing sections — only rendered when a signing key is configured #}
[commit]
    gpgsign = true
[tag]
    gpgSign = true
[gpg]
    format = {{ git_identity.work.signing_format | default("ssh") }}
{%- endif %}
