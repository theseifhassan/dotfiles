# {{ ansible_managed }}
# Git configuration — generated by the git role. Do not edit manually.
# Personal identity is the default. Work identity overrides for sky* projects.
[include]
    path = "{{ xdg_config_home }}/git/config-personal"

[includeIf "gitdir/i:{{ ansible_facts['user_dir'] }}/Desktop/sky*/"]
    path = "{{ xdg_config_home }}/git/config-work"
