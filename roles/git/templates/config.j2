# {{ ansible_managed }}
# Git configuration — generated by the git role. Do not edit manually.
# No default [user] block — repos outside the project directories below will
# require explicit identity configuration. This is intentional to prevent
# accidental commits under the wrong identity.

[includeIf "gitdir/i:{{ project_dirs.work }}/"]
    path = "{{ xdg_config_home }}/git/config-work"

[includeIf "gitdir/i:{{ project_dirs.personal }}/"]
    path = "{{ xdg_config_home }}/git/config-personal"
