# {{ ansible_managed }}
# Git configuration — generated by the git role. Do not edit manually.
# Personal identity is the default. Work identity is applied to any repo whose
# remote URL matches a pattern in `git_work_remote_globs` (keyed off the work
# SSH host alias), so it works regardless of folder or repo name.
# Note: a freshly `git init` repo with no remote yet uses the personal identity
# until a matching work remote is added.
[include]
    path = "{{ xdg_config_home }}/git/config-personal"

{% for glob in git_work_remote_globs %}
[includeIf "hasconfig:remote.*.url:{{ glob }}"]
    path = "{{ xdg_config_home }}/git/config-work"
{% endfor %}
