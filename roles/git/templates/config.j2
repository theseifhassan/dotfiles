# {{ ansible_managed }}
# Git configuration — generated by the git role. Do not edit manually.
# This machine carries exactly one profile ({{ profile }}); its identity is
# the only identity.

[user]
    name = {{ git_identity.name }}
    email = {{ git_identity.email }}
{% if git_identity.signing_key is defined and git_identity.signing_key %}
    signingKey = {{ git_identity.signing_key }}
[commit]
    gpgsign = true
[tag]
    gpgSign = true
[gpg]
    format = {{ git_identity.signing_format | default("ssh") }}
{% endif %}
