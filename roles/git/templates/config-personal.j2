# {{ ansible_managed }}
# Personal identity — generated by the git role.

[user]
    name = {{ git_identity.personal.name }}
    email = {{ git_identity.personal.email }}
{% if git_identity.personal.signing_key is defined and git_identity.personal.signing_key %}
    signingKey = {{ git_identity.personal.signing_key }}
[commit]
    gpgsign = true
[tag]
    gpgSign = true
[gpg]
    format = {{ git_identity.personal.signing_format | default("ssh") }}
{%- endif %}
