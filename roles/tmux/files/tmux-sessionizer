#!/usr/bin/env bash
# tmux-sessionizer — based on ThePrimeagen's script
# Opens or switches to a tmux session rooted at the selected project directory.

# Directories fzf searches for projects; each entry is listed one level deep.
# The worktrees glob expands to each project's worktree dir, so individual
# worktree checkouts (~/Desktop/worktrees/{project}/{branch}) are offered.
# nullglob keeps a missing/empty worktrees dir from passing a literal glob
# to find; dotglob keeps dot-prefixed projects visible.
shopt -s nullglob dotglob
search_paths=(
    "$HOME/Desktop"
    "$HOME/Desktop/worktrees"/*
)
shopt -u nullglob dotglob

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find "${search_paths[@]}" -mindepth 1 -maxdepth 1 -type d \
        -not -path "$HOME/Desktop/worktrees" 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Worktree checkouts are named "{project}/{worktree}" so worktrees of
# different projects (e.g. two "main" worktrees) don't collide; anything
# else gets its bare directory name.
if [[ $selected == "$HOME/Desktop/worktrees/"* ]]; then
    selected_name=$(basename "$(dirname "$selected")")/$(basename "$selected")
else
    selected_name=$(basename "$selected")
fi
selected_name=$(echo "$selected_name" | tr . _)
tmux_running=$(pgrep -x tmux)

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
        tmux new-session -s "$selected_name" -c "$selected"
        exit 0
    fi

    tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -z $TMUX ]]; then
    tmux attach-session -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
