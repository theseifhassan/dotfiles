#!/usr/bin/env python3
"""Claude Code PostToolUse hook: open freshly created git worktrees in Zed.

Zed's multi-workspace "New Thread In…" menu only lists workspaces that are
open in the window — a worktree created on disk (by SAW or by hand) is
invisible to it until something opens the path. `zed <path>` does exactly
that: with Zed's default `cli_default_open_behavior: existing_window` the
worktree joins the current window as a workspace, grouped under its main
repo, and becomes a thread target.

Reads the hook payload on stdin, finds `git worktree add` invocations in the
Bash command (including `git -C <repo> worktree add` and commands prefixed
by `cd <dir> &&`), and opens each created worktree path in Zed. Silent no-op
when Zed is missing, no GUI is reachable, or the path never materialized
(the command failed). Always exits 0 — this hook must never block the agent.
"""

import json
import os
import shlex
import shutil
import subprocess
import sys

# git global options that consume a following value (`git -C x worktree …`);
# the `=`-joined forms (--git-dir=x) are single tokens and fall through the
# generic dash-skip.
GIT_GLOBAL_OPTS_WITH_VALUE = {"-C", "-c", "--git-dir", "--work-tree", "--namespace", "--exec-path"}
# git worktree add options that consume a following value.
ADD_OPTIONS_WITH_VALUE = {"-b", "-B", "--orphan", "--reason"}
COMMAND_SEPARATORS = {"&&", "||", ";", "|", "&"}


def worktree_add_events(command):
    """Find every `git worktree add` in command.

    Returns a list of (raw_path, raw_base_chain): the worktree <path> argument
    plus the chain of directory changes that applied to it — inline `cd <dir>`
    segments and any `git -C <dir>` values, in order. Both are raw token text;
    the caller expands and resolves them.
    """
    try:
        tokens = shlex.split(command, comments=False)
    except ValueError:
        return []

    events = []
    cd_chain = []
    i = 0
    while i < len(tokens):
        token = tokens[i]

        if token in COMMAND_SEPARATORS:
            i += 1
            continue

        # Track `cd <dir>` so relative worktree paths later in the same
        # command resolve from where git actually ran. `cd` with no argument
        # (→ $HOME) is represented as "~".
        if token == "cd":
            if i + 1 < len(tokens) and tokens[i + 1] not in COMMAND_SEPARATORS:
                cd_chain.append(tokens[i + 1])
                i += 2
            else:
                cd_chain.append("~")
                i += 1
            continue

        # Transparent prefixes: `command git …`, `env [VAR=x…] git …`.
        if token in ("command", "env"):
            i += 1
            while i < len(tokens) and "=" in tokens[i] and not tokens[i].startswith("-"):
                i += 1
            continue

        if token != "git":
            i += 1
            continue

        # Inside a git invocation: skip global options, tracking -C.
        i += 1
        git_c_chain = []
        while i < len(tokens):
            token = tokens[i]
            if token in GIT_GLOBAL_OPTS_WITH_VALUE:
                if token == "-C" and i + 1 < len(tokens):
                    git_c_chain.append(tokens[i + 1])
                i += 2
            elif token.startswith("-"):
                i += 1
            else:
                break

        if not (
            i + 1 < len(tokens)
            and tokens[i] == "worktree"
            and tokens[i + 1] == "add"
        ):
            continue  # some other git subcommand; outer loop rescans from here

        i += 2
        positionals = []
        after_double_dash = False
        while i < len(tokens) and tokens[i] not in COMMAND_SEPARATORS:
            token = tokens[i]
            if after_double_dash:
                positionals.append(token)
                i += 1
            elif token in ADD_OPTIONS_WITH_VALUE:
                i += 2
            elif token == "--":
                after_double_dash = True
                i += 1
            elif token.startswith("-"):
                i += 1
            else:
                positionals.append(token)
                i += 1
        if positionals:
            events.append((positionals[0], cd_chain + git_c_chain))
    return events


def gui_reachable():
    if os.environ.get("SSH_CONNECTION") or os.environ.get("SSH_TTY"):
        return False
    if sys.platform == "darwin":
        return True
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))


def expand(raw):
    """Expand ~ and $VARs in a raw token the way the executing shell would."""
    return os.path.expandvars(os.path.expanduser(raw))


def resolve(base, chain, raw_path):
    """Resolve raw_path against base after applying the cd/-C chain."""
    for segment in chain:
        segment = expand(segment)
        base = segment if os.path.isabs(segment) else os.path.join(base, segment)
    path = expand(raw_path)
    if not os.path.isabs(path):
        path = os.path.join(base, path)
    return os.path.realpath(path)


def main():
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return

    if payload.get("tool_name") != "Bash":
        return
    command = (payload.get("tool_input") or {}).get("command") or ""
    if "worktree" not in command:
        return
    if not gui_reachable():
        return
    zed = shutil.which("zed")
    if not zed:
        return

    # The Bash tool's shell is profile-initialized (mise env included), but
    # this hook process may be GUI-launched and lack those vars — give the
    # one this convention depends on its mise-declared value as a fallback.
    os.environ.setdefault(
        "SAW_WORKTREE_ROOT", os.path.expanduser("~/Desktop/worktrees")
    )

    cwd = payload.get("cwd") or os.getcwd()
    seen = set()
    for raw_path, chain in worktree_add_events(command):
        path = resolve(cwd, chain, raw_path)
        if path in seen or "$" in path:
            continue  # duplicate, or an env var we couldn't expand
        seen.add(path)
        # The path existing as a worktree checkout doubles as the success
        # check: if `git worktree add` failed, there is nothing to open.
        if os.path.isdir(path) and os.path.exists(os.path.join(path, ".git")):
            subprocess.run(
                [zed, path],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )


if __name__ == "__main__":
    try:
        main()
    except Exception:  # noqa: BLE001 — a hook crash must never block the agent
        pass
    sys.exit(0)
