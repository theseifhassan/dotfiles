#!/usr/bin/env python3
"""Claude Code PostToolUse hook: open freshly created git worktrees in Zed.

Zed's multi-workspace "New Thread In…" menu only lists workspaces that are
open in the window — a worktree created on disk (by SAW or by hand) is
invisible to it until something opens the path. `zed <path>` does exactly
that: with Zed's default `cli_default_open_behavior: existing_window` the
worktree joins the current window as a workspace, grouped under its main
repo, and becomes a thread target.

Reads the hook payload on stdin, finds `git worktree add` invocations in the
Bash command, and opens each created worktree path in Zed. Silent no-op when
Zed is missing, no GUI is reachable, or the path never materialized (the
command failed). Always exits 0 — this hook must never block the agent.
"""

import json
import os
import shlex
import shutil
import subprocess
import sys

# git worktree add options that consume a following value; anything else
# starting with "-" is a bare flag. The first positional argument is <path>.
OPTIONS_WITH_VALUE = {"-b", "-B", "--orphan", "--reason"}
COMMAND_SEPARATORS = {"&&", "||", ";", "|"}


def worktree_add_paths(command):
    """Extract the <path> argument of every `git worktree add` in command."""
    try:
        tokens = shlex.split(command, comments=False)
    except ValueError:
        return []

    paths = []
    i = 0
    while i < len(tokens):
        if (
            tokens[i] == "git"
            and i + 2 < len(tokens)
            and tokens[i + 1] == "worktree"
            and tokens[i + 2] == "add"
        ):
            i += 3
            positionals = []
            while i < len(tokens) and tokens[i] not in COMMAND_SEPARATORS:
                token = tokens[i]
                if token in OPTIONS_WITH_VALUE:
                    i += 2
                elif token == "--":
                    i += 1
                elif token.startswith("-"):
                    i += 1
                else:
                    positionals.append(token)
                    i += 1
            if positionals:
                paths.append(positionals[0])
        else:
            i += 1
    return paths


def gui_reachable():
    if os.environ.get("SSH_CONNECTION") or os.environ.get("SSH_TTY"):
        return False
    if sys.platform == "darwin":
        return True
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))


def main():
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return

    if payload.get("tool_name") != "Bash":
        return
    command = (payload.get("tool_input") or {}).get("command") or ""
    if "worktree" not in command:
        return
    if not gui_reachable():
        return
    zed = shutil.which("zed")
    if not zed:
        return

    cwd = payload.get("cwd") or os.getcwd()
    seen = set()
    for raw_path in worktree_add_paths(command):
        path = os.path.expanduser(os.path.expandvars(raw_path))
        if not os.path.isabs(path):
            path = os.path.join(cwd, path)
        path = os.path.realpath(path)
        if path in seen:
            continue
        seen.add(path)
        # The path existing as a worktree checkout doubles as the success
        # check: if `git worktree add` failed, there is nothing to open.
        if os.path.isdir(path) and os.path.exists(os.path.join(path, ".git")):
            subprocess.run(
                [zed, path],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )


if __name__ == "__main__":
    try:
        main()
    except Exception:  # noqa: BLE001 — a hook crash must never block the agent
        pass
    sys.exit(0)
