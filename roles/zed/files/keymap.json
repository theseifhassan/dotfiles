// Zed keymap — XDG-native, deployed by roles/zed.
//
// Neovim-style window navigation: <ctrl-w> then h/j/k/l moves focus
// spatially across the whole workspace — the left dock (project panel), the
// main editor, the right dock, and the bottom dock (integrated terminal) —
// not just between editor splits.
//
// Zed's default vim keymap binds <ctrl-w> h/j/k/l to ActivatePaneLeft/Down/
// Up/Right, which only cycle editor panes and won't cross into the docks.
// ActivatePaneInDirection *does* cross into docks/terminal, and binding it in
// the "Dock || Terminal || VimControl" context makes the same keys work no
// matter where focus currently is.
[
  {
    // <ctrl-w> window prefix — works everywhere (editor, docks, terminal).
    // h/j/k/l move focus across the docks; z toggles the centered layout.
    // p fuzzy-jumps between project workspaces; ] / [ cycle them. The ctrl-w
    // variants are the terminal-capable counterparts to the <leader> maps
    // below, since a space leader can't be used while focus is in the terminal.
    "context": "Dock || Terminal || VimControl",
    "bindings": {
      "ctrl-w h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-w j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-w k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-w l": ["workspace::ActivatePaneInDirection", "Right"],
      "ctrl-w z": "workspace::ToggleCenteredLayout",
      "ctrl-w p": "projects::OpenRecent",
      "ctrl-w ]": "multi_workspace::NextProject",
      "ctrl-w [": "multi_workspace::PreviousProject"
    }
  },
  {
    // Leader (space) maps, scoped to vim normal mode so they don't clash with
    // typing. These are editor-only; use the ctrl-w variants above from the
    // terminal/docks.
    //   <leader><leader> — fuzzy-jump to a project/worktree workspace
    //   <leader>w        — focus the workspace switcher sidebar (visual list)
    //   <leader>z        — toggle the centered layout
    // (] p / [ p cycle workspaces by default in vim mode.)
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space space": "projects::OpenRecent",
      "space w": "multi_workspace::FocusWorkspaceSidebar",
      "space z": "workspace::ToggleCenteredLayout"
    }
  }
]
